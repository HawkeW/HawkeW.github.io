{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "baseUrl": "./",
    "paths": {
      "@components/*": ["./docs/.vuepress/components/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.vue",
    "**/.vuepress/**/*.ts",
    "**/.vuepress/**/*.vue"
  ],
  "exclude": [
    "node_modules"
  ],
}
